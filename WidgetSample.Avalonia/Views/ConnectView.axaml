<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WidgetSample.Avalonia.ViewModels"
             xmlns:diag="clr-namespace:DiagnosticExplorer;assembly=DiagnosticExplorer.Hosting"
             xmlns:conv="clr-namespace:WidgetSample.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="WidgetSample.Avalonia.Views.ConnectView"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Resources>
        <conv:ConnectionStateToColorConverter x:Key="StateToColor" />
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Bottom" Margin="0,4,0,4" Spacing="10">

        <!-- Overall status -->
        <TextBlock Text="{Binding StatusText}"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Right" />

        <!-- Per-site statuses -->
        <ItemsControl ItemsSource="{Binding SiteStatuses}"
                      HorizontalAlignment="Right">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="diag:SiteStatus">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="{Binding ConnectionState, Converter={StaticResource StateToColor}}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding Site.Url}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="Gray"
                                   Text="{Binding ConnectionState, StringFormat='({0})'}" />
                        <PathIcon Width="14" Height="14"
                                  VerticalAlignment="Center"
                                  Foreground="Orange"
                                  IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                  Data="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"
                                  ToolTip.Tip="{Binding ErrorMessage}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Start / Stop buttons -->
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Stop Diagnostics" Command="{Binding StopDiagnosticsCommand}" />
            <Button Content="Start Diagnostics" Command="{Binding StartDiagnosticsCommand}" />
        </StackPanel>

    </StackPanel>
</UserControl>


