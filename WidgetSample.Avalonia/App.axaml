<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WidgetSample.Avalonia.App"
             xmlns:local="using:WidgetSample.Avalonia"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Dark">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
             
    <Application.Styles>
        <semi:SemiTheme />
        <semi:DataGridSemiTheme />
        
         <Style Selector="TabControl">
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
        
        <Style Selector="HyperlinkButton.tiny">
            <Setter Property="FontSize" Value="10" />
        </Style>
            
    <Style Selector="TabItem">
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
    </Style>
        
        <Style Selector="DataGridColumnHeader">
    <Setter Property="BorderBrush" Value="#444"/>
    <Setter Property="BorderThickness" Value="0,1,1,1"/> <!-- Right and Bottom borders -->
    <Setter Property="Padding" Value="10,5"/>
</Style>
        
        <Style Selector="DataGrid">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#444"/>
            <Setter Property="VerticalGridLinesBrush" Value="#444"/>
        </Style>
        
        <Style Selector="HeaderedContentControl.Classic">
  <Setter Property="Template">
    <ControlTemplate>
      <Grid RowDefinitions="Auto,*" Margin="0 4 0 0">
        <!-- The Border -->
        <Border Grid.RowSpan="2" 
                Margin="8"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="4" />
        
        <!-- The Header (with a background to "cut" the border) -->
        <Border Background="{Binding $parent[Window].Background}" 
                Margin="12,0,0,0" 
                HorizontalAlignment="Left" 
                Padding="4,0">
          <ContentPresenter Content="{TemplateBinding Header}" 
                            FontWeight="Bold" />
        </Border>
        
        <!-- The Content -->
        <ContentPresenter Grid.Row="1" 
                          Content="{TemplateBinding Content}" 
                          Padding="12" />
      </Grid>
    </ControlTemplate>
  </Setter>
</Style>
         <!-- <FluentTheme /> -->
    </Application.Styles>
</Application>